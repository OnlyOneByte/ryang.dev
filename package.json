{
  "name": "ryang-dev",
  "private": true,
  "type": "module",
  "description": "Personal portfolio + homelab showcase (monorepo root).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "build": "bun run --filter web build",
    "preview": "bun run --filter web preview",
    "stack:up": "${CONTAINER_TOOL:-docker} compose -f infra/docker-compose.yml up -d",
    "stack:up:lite": "${CONTAINER_TOOL:-docker} compose -f infra/docker-compose.yml up -d web pocketbase umami umami-db wakapi ntfy uptime-kuma gotenberg",
    "stack:down": "${CONTAINER_TOOL:-docker} compose -f infra/docker-compose.yml down",
    "stack:dev": "${CONTAINER_TOOL:-docker} compose -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
