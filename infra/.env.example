# =====================================================================
# ryang.dev — environment template.  Copy to infra/.env and fill in.
# NEVER commit infra/.env (gitignored). All values here are placeholders.
# =====================================================================

# ---- public origin (cookie Secure flag, CORS, canonical URLs) ----
PUBLIC_SITE_URL=https://ryang.dev

# ---- infra: host port bind + pinned image tags (supply-chain) ----
# BIND_ADDR: interface for published ports. Default all-interfaces so the
# separate router box can reach them over the LAN. Set to the box's LAN IP to
# restrict. Do NOT use 127.0.0.1 unless the router runs on THIS host.
BIND_ADDR=0.0.0.0
# Pin image tags (or pin to a @sha256:<digest> for full reproducibility).
# Pocketbase MUST be >= 0.23 — the pb_hooks use the v0.23+ JSVM API
# (onRecordCreateRequest / onRecordAfterCreateSuccess / e.next()). On 0.22 those
# hooks silently DON'T register → guestbook/comments could be self-approved.
POCKETBASE_TAG=0.28.4
UMAMI_TAG=postgresql-v2.16
POSTGRES_TAG=16-alpine
WAKAPI_TAG=2.13.1
CAL_TAG=v4.7.5
NTFY_TAG=v2.11.0
KUMA_TAG=1.23.16
GOTENBERG_TAG=8.20.0

# ---- recruiter gate ----
# argon2 hash of your shared passphrase. Generate once (never store plaintext):
#   bun run apps/web/scripts/hash-passphrase.ts "your-passphrase"
RECRUITER_HASH=
# random 32+ byte secret that signs the recruiter session cookie:
#   openssl rand -hex 32
SESSION_SECRET=

# ---- pocketbase ----
PB_URL=http://pocketbase:8090
PB_PUBLIC_URL=https://pb.ryang.dev
# the superuser the web app authenticates as to read gated collections:
PB_SERVICE_EMAIL=service@ryang.dev
PB_SERVICE_PASSWORD=

# ---- ntfy (push notifications) ----
NTFY_URL=http://ntfy:80
NTFY_TOPIC=ryangdev-alerts-CHANGE_ME

# ---- wakapi (coding stats for the "Currently" widget) ----
WAKAPI_SALT=
WAKAPI_API_URL=https://wakapi.ryang.dev/api
WAKAPI_API_KEY=

# ---- github activity widget ----
GITHUB_USER=OnlyOneByte
GITHUB_TOKEN=

# ---- gotenberg (HTML -> PDF resume) ----
GOTENBERG_URL=http://gotenberg:3000

# ---- umami analytics ----
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=
UMAMI_DB_NAME=umami
UMAMI_APP_SECRET=

# ---- cal.com scheduling ----
CAL_DB_USER=calcom
CAL_DB_PASSWORD=
CAL_DB_NAME=calcom
CAL_NEXTAUTH_SECRET=
CAL_ENCRYPTION_KEY=
