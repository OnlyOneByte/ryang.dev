# Keep the build context lean and reproducible. Without this, the web image's
# `COPY . .` would overwrite the deps-stage node_modules with the HOST's (wrong
# platform, non-reproducible) and drag in .git/dist/secrets. node_modules is
# (re)installed INSIDE the image from package.json + bun.lock, never copied.

# deps — always installed in-image, never copied from host
**/node_modules

# build output — regenerated by `bun run build` in the build stage
**/dist
**/.astro
**/build
*.tsbuildinfo

# secrets — must NEVER enter the build context
infra/.env
.env
.env.*
!.env.example

# vcs / ci / docs not needed to build or run the app
.git
.github
docs

# pocketbase runtime data + docker volumes
services/pocketbase/pb_data
pb_data
infra/volumes

# logs, editor, OS cruft
*.log
.DS_Store
.idea
.vscode
*.swp
coverage
.nyc_output
