---
/** Top nav with the theme switcher island. Links are plain anchors (SSR). */
import ThemeSwitcher from '@/lib/theme/ThemeSwitcher.svelte';
---

<nav
  class="flex items-center justify-between border-b px-6 py-3 font-mono text-sm"
  style="border-color:var(--border)"
>
  <a href="/" class="font-bold" style="color:var(--text-strong)">
    ryang<span style="color:var(--accent)">.dev</span>
  </a>
  <div class="flex items-center gap-4" style="color:var(--muted)">
    <a href="/blog">blog</a>
    <a href="/guestbook">guestbook</a>
    <a href="/contact">contact</a>
    <a href="/colophon">colophon</a>
    <span
      class="rounded-theme border px-2 py-0.5 text-xs"
      style="border-color:var(--border);color:var(--muted)"
      title="Press ⌘K">⌘K</span>
    <ThemeSwitcher client:load />
  </div>
</nav>
