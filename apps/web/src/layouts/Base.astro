---
/**
 * Base layout. Renders the correct data-theme SERVER-SIDE from the `theme`
 * cookie, plus a no-flash inline script that reconciles before first paint.
 * Mounts the command palette (⌘K) globally; Nav/Footer optional via props.
 */
import '@/styles/global.css';
import { themeFromCookie } from '@/lib/theme/store';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.svelte';
import CommandPalette from '@/lib/cmdk/CommandPalette.svelte';
import UnlockToast from '@/lib/theme/UnlockToast.svelte';
import Analytics from '@/components/Analytics.astro';
import Terminal from '@/lib/fun/Terminal.svelte';
import { ViewTransitions } from 'astro:transitions';
import { getHomelabStatus } from '@/lib/widgets/status';

interface Props {
  title?: string;
  description?: string;
  chrome?: boolean; // show Nav + Footer (default true); false for /unlock, /private
  forceTheme?: string; // pin a legible theme (gate pages) regardless of cookie
  ogTitle?: string; // text on the share card (defaults to title)
  ogImage?: string; // override the og:image URL entirely
}
const {
  title = 'Angelo Yang',
  description = 'Software engineer & self-hoster.',
  chrome = true,
  forceTheme,
  ogTitle,
  ogImage,
} = Astro.props;
// Prerendered pages (e.g. blog posts) have no live request headers; guard the
// read so SSR theming works on-demand and prerender falls back to default
// (the no-flash inline script still applies the cookie theme client-side).
let cookieHeader: string | null = null;
try {
  cookieHeader = Astro.request.headers.get('cookie');
} catch {
  cookieHeader = null;
}
const theme = forceTheme ?? themeFromCookie(cookieHeader);

// Live homelab status for the footer (fail-soft → static placeholder).
const homelab = await getHomelabStatus();
const statusLabel = homelab ? `${homelab.up}/${homelab.total}` : '9/9';

// Build a canonical absolute URL + the OG image (dynamic card endpoint unless
// the page supplies its own). Astro.site is configured to https://ryang.dev.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const cardTitle = ogTitle ?? title;
const ogUrl =
  ogImage ??
  new URL(
    `/og/${encodeURIComponent(cardTitle)}.png?subtitle=${encodeURIComponent(description)}`,
    Astro.site
  ).href;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Open Graph + Twitter share cards */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />
    <ViewTransitions />
    <Analytics />
    {/* No-flash: reconcile data-theme before any CSS paints. Skipped when the
        page pins a theme (gate pages) so the cookie can't override it. */}
    {!forceTheme && (
      <script is:inline>
        document.documentElement.dataset.theme =
          (document.cookie.match(/(?:^|;\s*)theme=([\w-]+)/)?.[1]) || 'cyberpunk';
      </script>
    )}
  </head>
  <body class="scanline-overlay flex min-h-screen flex-col">
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome && <Nav />}
    <div id="main" class="flex-1">
      <slot />
    </div>
    {chrome && <Footer status={statusLabel} client:load />}
    {/* ⌘K palette + unlock toast — global, idle-loaded so they never block paint */}
    <CommandPalette client:idle />
    <UnlockToast client:idle />
    <Terminal client:idle />
  </body>
</html>
