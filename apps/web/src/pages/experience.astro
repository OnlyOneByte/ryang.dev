---
import Base from '@/layouts/Base.astro';
import { publicClient } from '@/lib/pb/client';

/**
 * Experience — professional work history (distinct from /work, which is
 * personal projects). PB `work_experience` with a static fallback, same pattern
 * as /work. PUBLIC content only: no internal service/package codenames, CR
 * details, or confidential architecture (this site is public).
 */
type Exp = {
  company: string; role: string; startDate: string; endDate?: string;
  summary?: string; highlights: string[]; tech: string[];
};

let roles: Exp[] = [];
try {
  const pb = publicClient();
  const rows = await pb.collection('work_experience').getFullList({
    filter: 'visible = true', sort: 'order',
  });
  roles = rows.map((r: any) => ({
    company: r.company, role: r.role, startDate: r.startDate, endDate: r.endDate,
    summary: r.summary, highlights: r.highlights ?? [], tech: r.tech ?? [],
  }));
} catch {
  roles = [
    {
      company: 'Amazon — Prime Video', role: 'Software Engineer',
      startDate: '2022', endDate: '',
      summary: 'Building and operating large-scale video streaming and playback systems for a global audience.',
      highlights: [], tech: ['TypeScript', 'Java', 'AWS', 'Distributed Systems'],
    },
    {
      company: 'PIMCO — Platform Engineering', role: 'Platform Engineer',
      startDate: '2020', endDate: '2022',
      summary: 'Built and operated internal developer platform and observability tooling for engineering teams.',
      highlights: ['Observability with Datadog across services (dashboards, monitors, SLOs).'],
      tech: ['Datadog', 'CI/CD', 'Cloud', 'Observability'],
    },
  ];
}

const period = (e: Exp) => `${e.startDate} – ${e.endDate || 'present'}`;
---

<Base title="Experience — Angelo Yang" description="Professional work history.">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <p class="text-sm" style="color:var(--accent)">$ cat ~/.experience</p>
    <h1 class="mt-2 text-3xl font-extrabold" style="color:var(--text-strong)">Experience</h1>
    <p class="mt-2 text-sm" style="color:var(--muted)">Where I've worked and what I worked on.</p>

    <ol class="mt-10 space-y-10 border-l pl-6" style="border-color:var(--border)">
      {roles.map((e) => (
        <li class="relative">
          <span class="absolute -left-[1.7rem] top-1.5 h-3 w-3 rounded-full"
                style="background:var(--accent)"></span>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h2 class="text-lg font-bold" style="color:var(--text-strong)">{e.company}</h2>
            <span class="text-xs" style="color:var(--muted)">{period(e)}</span>
          </div>
          <p class="text-sm" style="color:var(--accent)">{e.role}</p>
          {e.summary && <p class="mt-2 text-sm" style="color:var(--muted)">{e.summary}</p>}
          {e.highlights.length > 0 && (
            <ul class="mt-3 space-y-1 text-sm" style="color:var(--text)">
              {e.highlights.map((h) => (
                <li class="flex gap-2">
                  <span style="color:var(--accent)">▸</span><span>{h}</span>
                </li>
              ))}
            </ul>
          )}
          {e.tech.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2 text-xs">
              {e.tech.map((t) => (
                <span class="rounded-theme border px-2 py-0.5"
                      style="border-color:var(--border);color:var(--accent)">{t}</span>
              ))}
            </div>
          )}
        </li>
      ))}
    </ol>
  </main>
</Base>
