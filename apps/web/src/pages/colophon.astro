---
import Base from '@/layouts/Base.astro';
import { publicClient } from '@/lib/pb/client';

/**
 * Colophon — an interactive architecture diagram of THIS site's own stack,
 * plus the "uses" list (hardware/software/tools). Click a node to read what it
 * does. Pure SVG + a tiny inline script (no deps), styled entirely through
 * theme tokens so it re-skins with the active theme.
 */

// --- uses list (merged in from the former /uses page; PB with static fallback) ---
type UsesItem = { category: string; name: string; description?: string; url?: string };
const CATS = ['hardware', 'software', 'dev-tools', 'desk'] as const;
let usesItems: UsesItem[] = [];
try {
  const pb = publicClient();
  const rows = await pb.collection('uses_items').getFullList({ sort: 'order' });
  usesItems = rows.map((r: any) => ({ category: r.category, name: r.name, description: r.description, url: r.url }));
} catch {
  usesItems = [
    { category: 'hardware', name: 'Homelab box', description: 'Docker host running the whole self-hosted stack' },
    { category: 'hardware', name: 'Router w/ Caddy', description: 'TLS termination + reverse proxy' },
    { category: 'software', name: 'Pocketbase', description: 'Auth, SQLite, file storage, realtime' },
    { category: 'software', name: 'Umami', description: 'Cookieless analytics' },
    { category: 'dev-tools', name: 'Bun', description: 'Runtime, package manager, bundler, test runner' },
    { category: 'dev-tools', name: 'Astro', description: 'Zero-JS-by-default SSR framework' },
    { category: 'desk', name: 'Mechanical keyboard', description: 'Where the 4h12m/day happens' },
  ];
}
const usesGrouped = CATS.map((c) => ({ cat: c, list: usesItems.filter((i) => i.category === c) }))
  .filter((g) => g.list.length > 0);

const NODES = [
  { id: 'router', label: 'Router Caddy', x: 40, y: 30, role: 'TLS termination + reverse proxy (external box). The only public entry point.' },
  { id: 'web', label: 'web (Astro)', x: 250, y: 30, role: 'Astro SSR on Bun. Zero-JS-by-default; islands hydrate only where needed.' },
  { id: 'pb', label: 'Pocketbase', x: 250, y: 130, role: 'Auth, SQLite, file storage, realtime, admin UI. Backs projects, guestbook, comments, recruiter content.' },
  { id: 'umami', label: 'Umami', x: 460, y: 30, role: 'Cookieless, privacy-first analytics (+ its own Postgres).' },
  { id: 'wakapi', label: 'Wakapi', x: 460, y: 95, role: 'Self-hosted WakaTime; feeds the "Currently" coding-stats block.' },
  { id: 'gotenberg', label: 'Gotenberg', x: 460, y: 160, role: 'HTML → PDF; renders the résumé on demand from live data.' },
  { id: 'ntfy', label: 'Ntfy', x: 460, y: 225, role: 'Phone push on contact-form submit + recruiter unlock.' },
];
const EDGES = [
  ['router', 'web'], ['web', 'pb'], ['web', 'umami'],
  ['web', 'wakapi'], ['web', 'gotenberg'], ['pb', 'ntfy'],
];
const pos = (id: string) => NODES.find((n) => n.id === id)!;
---

<Base title="Colophon — Angelo Yang">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <p class="text-sm" style="color:var(--accent)">$ cat ~/.colophon</p>
    <h1 class="mt-2 text-3xl font-extrabold" style="color:var(--text-strong)">How this site is built</h1>
    <p class="mt-2 text-sm" style="color:var(--muted)">
      Self-hosted, Bun-built, theme-token-driven. Click a node to see what it does.
    </p>

    <svg viewBox="0 0 620 270" class="mt-8 w-full" role="img" aria-label="Architecture diagram">
      {EDGES.map(([a, b]) => {
        const pa = pos(a), pb2 = pos(b);
        return (
          <line x1={pa.x + 70} y1={pa.y + 16} x2={pb2.x} y2={pb2.y + 16}
                stroke="var(--border)" stroke-width="1.5" />
        );
      })}
      {NODES.map((n) => (
        <g class="node" data-role={n.role} style="cursor:pointer">
          <rect x={n.x} y={n.y} width="140" height="32" rx="4"
                fill="var(--panel)" stroke="var(--accent)" stroke-width="1.5" />
          <text x={n.x + 70} y={n.y + 21} text-anchor="middle"
                font-size="12" font-family="var(--font-mono)" fill="var(--text)">{n.label}</text>
        </g>
      ))}
      {/* 🧩 hidden scavenger node — faint, in the corner; claims the fragment on click. */}
      <text id="egg-node" x="606" y="262" text-anchor="end" font-size="11"
            style="cursor:pointer;opacity:.18" aria-hidden="true">🧩</text>
    </svg>

    <div id="node-detail" class="mt-4 rounded-theme border p-4 text-sm"
         style="background:var(--panel);border-color:var(--border);color:var(--muted)">
      Click a node above to read its role.
    </div>

    {/* Uses — moved here from the former /uses page (/uses now redirects to #uses). */}
    <section id="uses" class="mt-16 scroll-mt-8">
      <p class="text-sm" style="color:var(--accent)">$ cat ~/.uses</p>
      <h2 class="mt-2 text-2xl font-extrabold" style="color:var(--text-strong)">Uses</h2>
      <p class="mt-2 text-sm" style="color:var(--muted)">Hardware, software, and tools I actually use.</p>

      {usesGrouped.map((g) => (
        <section class="mt-8">
          <h3 class="text-sm uppercase tracking-wider" style="color:var(--accent)">{g.cat}</h3>
          <ul class="mt-3 divide-y" style="border-color:var(--border)">
            {g.list.map((i) => (
              <li class="flex items-baseline justify-between gap-4 py-2">
                <div>
                  <span class="font-bold" style="color:var(--text-strong)">
                    {i.url ? <a href={i.url} style="color:var(--accent)">{i.name} ↗</a> : i.name}
                  </span>
                  {i.description && <span class="ml-2 text-sm" style="color:var(--muted)">— {i.description}</span>}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </section>

    <p class="mt-16 text-xs" style="color:var(--muted)">
      Source: <a href="https://github.com/OnlyOneByte/ryang.dev" style="color:var(--accent)">OnlyOneByte/ryang.dev</a>
      · built with Astro, Pocketbase, Bun · 15-theme engine
    </p>
  </main>

  <script is:inline>
    const detail = document.getElementById('node-detail');
    document.querySelectorAll('.node').forEach((g) => {
      g.addEventListener('click', () => {
        detail.textContent = g.getAttribute('data-role');
        detail.style.color = 'var(--text)';
      });
    });
  </script>

  {/* 🧩 module script (bundled, so it can import) — claims the colophon fragment. */}
  <script>
    import { findFragment } from '@/lib/eggs/store';
    document.getElementById('egg-node')?.addEventListener('click', () => findFragment('colophon'));
  </script>
</Base>
