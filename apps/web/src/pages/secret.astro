---
import Base from '@/layouts/Base.astro';
import { verifyValue } from '@/lib/auth/session';
import { EGG_COOKIE, EGG_VALUE } from '@/pages/api/egg/complete';

/**
 * /secret — the scavenger-hunt reward page. Gated on the signed completion
 * cookie set by /api/egg/complete (not localStorage, which is client-trivial to
 * forge). Not linked anywhere; pinned to a legible theme. Pure whimsy.
 */
export const prerender = false;

const token = Astro.cookies.get(EGG_COOKIE)?.value;
const unlocked = verifyValue(token, EGG_VALUE);
---

<Base title="🧩 secret" description="" chrome={true} forceTheme="cyberpunk">
  <main class="mx-auto max-w-2xl px-6 py-20 text-center font-mono">
    {unlocked ? (
      <>
        <pre class="inline-block text-left text-xs leading-tight" style="color:var(--accent)">{`
   _____________
  |  ___   ___  |
  | |   | |   | |   you found
  | |___| |___| |   everything.
  |_____________|
        | |
       _|_|_       🧩 × 7
`}</pre>
        <h1 class="mt-6 text-3xl font-extrabold" style="color:var(--text-strong)">You found them all.</h1>
        <p class="mt-3 text-sm" style="color:var(--muted)">
          Seven fragments, scattered across the site. If you went looking for all
          of them, you're exactly the kind of curious I like to work with.
        </p>
        <p class="mt-6 text-sm">
          <a href="/contact" style="color:var(--accent)">say hi →</a>
          <span class="mx-2" style="color:var(--muted)">·</span>
          <a href="/cal" style="color:var(--accent)">book a call →</a>
        </p>
      </>
    ) : (
      <>
        <h1 class="text-2xl font-extrabold" style="color:var(--text-strong)">🔒 not yet</h1>
        <p class="mt-3 text-sm" style="color:var(--muted)">
          There's a scavenger hunt hidden across this site — seven 🧩 fragments.
          Find them all and this page changes. (Start by opening the devtools
          console, or pressing <span style="color:var(--accent)">`</span> for a shell.)
        </p>
      </>
    )}
  </main>
</Base>
