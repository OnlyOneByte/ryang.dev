---
import Base from '@/layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Comments from '@/lib/comments/Comments.svelte';
import Reactions from '@/lib/interactions/Reactions.svelte';

// Prerender posts at build (content is git-backed MDX). Comments hydrate
// client-side, so a static shell is correct + fast.
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// reading time from rendered body length (rough words/200wpm)
const words = post.body.split(/\s+/).length;
const mins = Math.max(1, Math.round(words / 200));
---

<Base
  title={`${post.data.title} — Angelo Yang`}
  description={post.data.description}
  ogTitle={post.data.title}
>
  <main class="mx-auto max-w-2xl px-6 py-16">
    <a href="/blog" class="font-mono text-sm" style="color:var(--accent)">← all posts</a>
    <h1 class="mt-3 text-3xl font-extrabold leading-tight" style="color:var(--text-strong)">
      {post.data.title}
    </h1>
    <div class="mt-2 flex flex-wrap items-center gap-2 font-mono text-xs" style="color:var(--muted)">
      <time>{fmt(post.data.pubDate)}</time>
      <span>·</span>
      <span>{mins} min read</span>
      {post.data.tags.map((t) => (
        <span class="rounded-theme border px-2 py-0.5"
              style="border-color:var(--border);color:var(--accent)">{t}</span>
      ))}
    </div>

    <article class="post mt-8 leading-relaxed" style="color:var(--text)">
      <Content />
    </article>

    <div class="mt-10">
      <Reactions targetType="post" targetId={post.slug} client:visible />
    </div>

    <hr class="my-12" style="border-color:var(--border)" />
    <Comments postSlug={post.slug} client:visible />
  </main>
</Base>

<style is:global>
  /* Minimal prose styling via theme tokens (Tailwind v4 has no prose plugin
     wired; keep it lightweight and theme-aware). */
  .post h2 { font-size: 1.35rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--text-strong); }
  .post h3 { font-size: 1.1rem; font-weight: 700; margin: 1.5rem 0 0.5rem; color: var(--text-strong); }
  .post p { margin: 0.9rem 0; }
  .post ul { margin: 0.9rem 0; padding-left: 1.25rem; list-style: disc; }
  .post li { margin: 0.3rem 0; }
  .post a { color: var(--accent); text-decoration: underline; }
  .post code { font-family: var(--font-mono); background: var(--panel-2); padding: 0.1rem 0.35rem; border-radius: 4px; font-size: 0.9em; }
  .post pre { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; overflow-x: auto; margin: 1.2rem 0; }
  .post pre code { background: none; padding: 0; }
</style>
