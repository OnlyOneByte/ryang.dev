---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { publicClient } from '@/lib/pb/client';

/**
 * Blog index — merges two sources (the hybrid model):
 *  - git-backed MDX in src/content/blog → /blog/<slug> (prerendered, Shiki)
 *  - PocketBase `posts` (published && !gated) → /blog/p/<slug> (SSR, runtime
 *    markdown). These can be added from the private repo via a DB seed, no rebuild.
 * Gated PB posts never appear here (listRule excludes them); they're reachable
 * by direct link only, behind the recruiter gate.
 */
type Entry = { href: string; title: string; description: string; date: Date; tags: string[]; source: 'mdx' | 'pb' };

// 1) git MDX
const mdx: Entry[] = (await getCollection('blog', ({ data }) => !data.draft)).map((p) => ({
  href: `/blog/${p.slug}`,
  title: p.data.title,
  description: p.data.description,
  date: p.data.pubDate,
  tags: p.data.tags,
  source: 'mdx',
}));

// 2) PB posts (fail-soft if PB is down — the git posts still render)
let pb: Entry[] = [];
try {
  const client = publicClient();
  const rows = await client.collection('posts').getFullList({
    filter: 'published = true && gated = false',
    sort: '-pubDate',
  });
  pb = rows.map((r: any) => ({
    href: `/blog/p/${r.slug}`,
    title: r.title,
    description: r.description ?? '',
    date: r.pubDate ? new Date(r.pubDate) : new Date(0),
    tags: r.tags ?? [],
    source: 'pb' as const,
  }));
} catch {
  pb = [];
}

const posts = [...mdx, ...pb].sort((a, b) => b.date.getTime() - a.date.getTime());
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Blog — Angelo Yang" description="Notes on self-hosting, systems, and building things.">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <div class="flex items-center justify-between">
      <p class="text-sm" style="color:var(--accent)">$ ls ~/blog</p>
      <a href="/rss.xml" class="text-xs" style="color:var(--muted)">RSS ↗</a>
    </div>
    <h1 class="mt-2 text-3xl font-extrabold" style="color:var(--text-strong)">Blog</h1>

    <ul class="mt-8 space-y-6">
      {posts.map((p) => (
        <li>
          <a href={p.href} class="block rounded-theme border p-4 transition hover:opacity-90"
             style="background:var(--panel);border-color:var(--border)">
            <div class="flex items-baseline justify-between gap-4">
              <span class="font-bold" style="color:var(--text-strong)">{p.title}</span>
              <span class="shrink-0 text-xs" style="color:var(--muted)">{fmt(p.date)}</span>
            </div>
            <p class="mt-1.5 text-sm" style="color:var(--muted)">{p.description}</p>
            <div class="mt-3 flex gap-2 text-xs">
              {p.tags.map((t) => (
                <span class="rounded-theme border px-2 py-0.5"
                      style="border-color:var(--border);color:var(--accent)">{t}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>
