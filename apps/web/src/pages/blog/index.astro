---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Blog — Angelo Yang" description="Notes on self-hosting, systems, and building things.">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <div class="flex items-center justify-between">
      <p class="text-sm" style="color:var(--accent)">$ ls ~/blog</p>
      <a href="/rss.xml" class="text-xs" style="color:var(--muted)">RSS ↗</a>
    </div>
    <h1 class="mt-2 text-3xl font-extrabold" style="color:var(--text-strong)">Blog</h1>

    <ul class="mt-8 space-y-6">
      {posts.map((p) => (
        <li>
          <a href={`/blog/${p.slug}`} class="block rounded-theme border p-4 transition hover:opacity-90"
             style="background:var(--panel);border-color:var(--border)">
            <div class="flex items-baseline justify-between gap-4">
              <span class="font-bold" style="color:var(--text-strong)">{p.data.title}</span>
              <span class="shrink-0 text-xs" style="color:var(--muted)">{fmt(p.data.pubDate)}</span>
            </div>
            <p class="mt-1.5 text-sm" style="color:var(--muted)">{p.data.description}</p>
            <div class="mt-3 flex gap-2 text-xs">
              {p.data.tags.map((t) => (
                <span class="rounded-theme border px-2 py-0.5"
                      style="border-color:var(--border);color:var(--accent)">{t}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Base>
