---
import Base from '@/layouts/Base.astro';
---

<Base title="Richard Yang — Software Engineer & Self-Hoster">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <p class="text-sm" style="color:var(--accent)">$ whoami</p>
    <h1 class="mt-3 text-5xl font-extrabold tracking-tight" style="color:var(--text-strong)">
      Richard Yang
    </h1>
    <p class="mt-3 max-w-xl text-base" style="color:var(--muted)">
      Software engineer who self-hosts everything. Fast, durable systems — and
      the homelab they run on.
    </p>

    <!-- "Currently" block (Wakapi-fed; static placeholder for scaffold) -->
    <div
      class="mt-6 inline-flex flex-wrap items-center gap-2 rounded-theme border px-4 py-2 text-sm"
      style="background:var(--panel);border-color:var(--border)"
    >
      <span style="color:var(--muted)">currently</span>
      <span style="color:var(--accent)">● coding in Rust</span>
      <span style="color:var(--muted)">·</span>
      <span>⌨️ 4h 12m today</span>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/resume.pdf"
        class="rounded-theme px-4 py-2 text-sm font-semibold"
        style="background:var(--accent);color:var(--accent-ink)">⬇ Résumé PDF</a>
      <a
        href="/unlock"
        class="rounded-theme border px-4 py-2 text-sm"
        style="border-color:var(--border);color:var(--text)">🔒 Recruiter mode</a>
    </div>

    <footer class="mt-16 flex justify-between text-xs" style="color:var(--muted)">
      <span>built with astro · pocketbase · self-hosted ♥</span>
      <span style="color:var(--accent)">▦ scaffold v0.1</span>
    </footer>
  </main>
</Base>
