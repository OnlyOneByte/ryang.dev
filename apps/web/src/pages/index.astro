---
import Base from '@/layouts/Base.astro';
import { publicClient } from '@/lib/pb/client';
import { getCurrently } from '@/lib/widgets/wakapi';
import { getGithubSummary } from '@/lib/widgets/github';

// Live widgets (server-fetched, cached, fail-soft → null when unconfigured).
const currently = await getCurrently();
const github = await getGithubSummary();

/**
 * Home. Pulls featured projects from Pocketbase when reachable; falls back to a
 * small static set so the page renders standalone (no backend in dev). The
 * "Currently" block is a placeholder until the Wakapi widget lands (M6).
 */
type Project = { title: string; summary: string; tech: string[]; slug?: string };

let featured: Project[] = [];
try {
  const pb = publicClient();
  const rows = await pb.collection('projects').getList(1, 2, {
    filter: 'featured = true && status = "active"',
    sort: 'order',
  });
  featured = rows.items.map((r: any) => ({
    title: r.title, summary: r.summary, tech: r.tech ?? [], slug: r.slug,
  }));
} catch {
  // backend not up (dev) — fall back to representative content
  featured = [
    { title: 'Homelab Mesh', summary: 'Self-hosted orchestration across 3 nodes. Docker, Caddy, zero-trust.', tech: ['Go', 'Docker'] },
    { title: 'VROOM', summary: 'Vehicle cost tracker. 1700+ tests, offline-first sync, analytics.', tech: ['Svelte', 'TS'] },
  ];
}
---

<Base title="Angelo Yang — Software Engineer & Self-Hoster">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <p class="text-sm" style="color:var(--accent)">$ whoami</p>
    <h1 class="mt-3 text-5xl font-extrabold tracking-tight" style="color:var(--text-strong)">
      Angelo Yang
    </h1>
    <p class="mt-3 max-w-xl text-base" style="color:var(--muted)">
      Software engineer who self-hosts everything. Fast, durable systems — and
      the homelab they run on.
    </p>

    <div
      class="mt-6 inline-flex flex-wrap items-center gap-2 rounded-theme border px-4 py-2 text-sm"
      style="background:var(--panel);border-color:var(--border)"
    >
      <span style="color:var(--muted)">currently</span>
      <span style="color:var(--accent)">
        ● {currently?.topLanguage ? `coding in ${currently.topLanguage}` : 'building things'}
      </span>
      <span style="color:var(--muted)">·</span>
      <span>⌨ {currently?.todayText ?? '—'} today</span>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/resume.pdf" class="rounded-theme px-4 py-2 text-sm font-semibold"
         style="background:var(--accent);color:var(--accent-ink)">⬇ Résumé PDF</a>
      <a href="/unlock" class="rounded-theme border px-4 py-2 text-sm"
         style="border-color:var(--border);color:var(--text)">🔒 Recruiter mode</a>
    </div>

    <section class="mt-14">
      <p class="text-sm" style="color:var(--accent)">$ ls ~/work --featured</p>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {featured.map((p) => (
          <a
            href={p.slug ? `/work/${p.slug}` : '/work'}
            class="block rounded-theme border p-4 transition hover:opacity-90"
            style="background:var(--panel);border-color:var(--border)"
          >
            <div class="font-bold" style="color:var(--text-strong)">{p.title}</div>
            <div class="mt-1.5 text-sm" style="color:var(--muted)">{p.summary}</div>
            <div class="mt-3 flex gap-2 text-xs">
              {p.tech.map((t) => (
                <span class="rounded-theme border px-2 py-0.5"
                      style="border-color:var(--border);color:var(--accent)">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      <a href="/work" class="mt-4 inline-block text-sm" style="color:var(--accent)">
        all work →
      </a>
    </section>

    {github && (
      <section class="mt-14">
        <p class="text-sm" style="color:var(--accent)">$ gh activity</p>
        <div class="mt-4 flex flex-wrap gap-4 text-sm" style="color:var(--muted)">
          <span><span style="color:var(--text-strong)">{github.publicRepos}</span> repos</span>
          <span><span style="color:var(--text-strong)">{github.followers}</span> followers</span>
          {github.recentPushes[0] && (
            <span>last push → <span style="color:var(--text)">{github.recentPushes[0].repo}</span></span>
          )}
        </div>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {github.topRepos.map((r) => (
            <a href={`https://github.com/${github.user}/${r.name}`} rel="noopener"
               class="block rounded-theme border p-3 transition hover:opacity-90"
               style="background:var(--panel);border-color:var(--border)">
              <div class="flex items-center justify-between">
                <span class="font-bold" style="color:var(--text-strong)">{r.name}</span>
                <span class="text-xs" style="color:var(--muted)">★ {r.stars}</span>
              </div>
              {r.description && <div class="mt-1 text-xs" style="color:var(--muted)">{r.description}</div>}
              {r.language && <div class="mt-2 text-xs" style="color:var(--accent)">{r.language}</div>}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Base>
