---
import Base from '@/layouts/Base.astro';
import { publicClient } from '@/lib/pb/client';
import { getCurrently } from '@/lib/widgets/wakapi';
import { getGithubSummary } from '@/lib/widgets/github';
import { getProjects } from '@/lib/widgets/projects';

/**
 * "Me" — the single unified page: intro, projects (from GitHub), and experience
 * (professional history) on one scroll, in #projects / #experience sections.
 *
 * The four server-side sources (Wakapi, GitHub summary, projects, PB experience)
 * run in PARALLEL — all fail-soft (null / fallback), so the page always renders.
 */
type Exp = {
  company: string; role: string; startDate: string; endDate?: string;
  summary?: string; highlights: string[]; tech: string[];
};

async function getExperience(): Promise<Exp[]> {
  try {
    const pb = publicClient();
    const rows = await pb.collection('work_experience').getFullList({
      filter: 'visible = true', sort: 'order',
    });
    return rows.map((r: any) => ({
      company: r.company, role: r.role, startDate: r.startDate, endDate: r.endDate,
      summary: r.summary, highlights: r.highlights ?? [], tech: r.tech ?? [],
    }));
  } catch {
    return EXPERIENCE_FALLBACK;
  }
}

// PUBLIC content only: no internal service/package codenames, CR details, or
// confidential architecture (this site is public).
const EXPERIENCE_FALLBACK: Exp[] = [
  {
    company: 'Amazon — Prime Video Sports', role: 'Software Engineer II',
    startDate: '2022', endDate: '',
    summary: 'Design and operate highly-available, high-throughput services and ETL pipelines for live sports streaming at global scale — from ML-driven event monitoring to developer self-service tooling.',
    highlights: [
      'Engineer highly-available, high-throughput backend services on AWS that hold up under live-event traffic spikes — stress-tested in production during Black Friday Football.',
      'Design and operate ETL pipelines that ingest, transform, and serve large volumes of catalog and event data across the Prime Video Sports platform.',
      'Built a scalable VLM-based recognition system for automated event monitoring, deployed catalog-wide.',
      'Drove a cost-optimization effort that reclaimed over $350K in underutilized AWS resources in the first year.',
      'Shipped a self-service image-slate portal and championed AI-assisted log diagnosis, cutting onboarding from two developer-days to none and enabling self-service root-causing for other teams.',
    ],
    tech: ['Java', 'Kotlin', 'Python', 'TypeScript', 'Rust', 'AWS', 'MongoDB', 'ETL', 'Distributed Systems'],
  },
  {
    company: 'PIMCO — Platform Engineering', role: 'Software Engineer',
    startDate: '2020', endDate: '2022',
    summary: 'Built the internal developer platform — identity, observability, and CI/CD — and led the on-prem to AWS migration for engineering teams firm-wide.',
    highlights: [
      'Architected the firm\'s transition to Okta with in-house abstractions for other developers, reducing onboarding from several weeks to two days.',
      'Onboarded Datadog and built migration tooling from legacy monitoring platforms, cutting mean-time-to-root-cause from 9 days to 2.',
      'Created CI/CD pipelines that made full Okta and Datadog adoption a one-commit change for most applications in the firm.',
      'Drove planning and execution of the on-premise to AWS migration, architecting bespoke solutions for internal teams as needed.',
    ],
    tech: ['Java', 'Okta', 'Datadog', 'CI/CD', 'AWS', 'Observability'],
  },
];

const period = (e: Exp) => `${e.startDate} – ${e.endDate || 'present'}`;

// Parallel — independent sources, all fail-soft.
const [currently, github, projects, experience] = await Promise.all([
  getCurrently(),
  getGithubSummary(),
  getProjects(),
  getExperience(),
]);
---

<Base title="Angelo Yang — Software Engineer & Self-Hoster">
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <p class="text-sm" style="color:var(--accent)">$ whoami</p>
    <h1 class="mt-3 text-5xl font-extrabold tracking-tight" style="color:var(--text-strong)">
      Angelo Yang
    </h1>
    <p class="mt-3 max-w-xl text-base" style="color:var(--muted)">
      Software engineer who self-hosts everything. Fast, durable systems — and
      the homelab they run on.
    </p>

    <div
      class="mt-6 inline-flex flex-wrap items-center gap-2 rounded-theme border px-4 py-2 text-sm"
      style="background:var(--panel);border-color:var(--border)"
    >
      <span style="color:var(--muted)">currently</span>
      <span style="color:var(--accent)">
        ● {currently?.topLanguage ? `coding in ${currently.topLanguage}` : 'building things'}
      </span>
      <span style="color:var(--muted)">·</span>
      <span>⌨ {currently?.todayText ?? '—'} today</span>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/cal" class="rounded-theme px-4 py-2 text-sm font-semibold"
         style="background:var(--accent);color:var(--accent-ink)">📅 Book a call</a>
      <a href="/resume.pdf" class="rounded-theme border px-4 py-2 text-sm"
         style="border-color:var(--border);color:var(--text)">⬇ Résumé PDF</a>
      <a href="/unlock" class="rounded-theme border px-4 py-2 text-sm"
         style="border-color:var(--border);color:var(--text)">🔒 Recruiter mode</a>
    </div>

    <!-- Projects (pulled from GitHub) -->
    <section id="projects" class="mt-16 scroll-mt-20">
      <p class="text-sm" style="color:var(--accent)">$ ls ~/projects</p>
      <h2 class="mt-2 text-2xl font-extrabold" style="color:var(--text-strong)">Projects</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {projects.map((p) => (
          <div
            class="relative rounded-theme border p-4 transition hover:opacity-90"
            style="background:var(--panel);border-color:var(--border)"
          >
            {/* Stretched link: whole card → repo. Nested anchors are invalid HTML,
                so this is an absolute overlay; the detail link below sits above it. */}
            <a href={p.repoUrl} rel="noopener" target="_blank"
               class="absolute inset-0 rounded-theme" aria-label={`${p.name} on GitHub`}></a>
            <div class="flex items-center justify-between">
              <span class="font-bold" style="color:var(--text-strong)">{p.name}</span>
              {p.stars > 0 && (
                <span class="text-xs" style="color:var(--muted)">★ {p.stars}</span>
              )}
            </div>
            {p.summary && (
              <div class="mt-1.5 text-sm" style="color:var(--muted)">{p.summary}</div>
            )}
            <div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
              {p.tech.map((t) => (
                <span class="rounded-theme border px-2 py-0.5"
                      style="border-color:var(--border);color:var(--accent)">{t}</span>
              ))}
            </div>
            <div class="mt-3 flex flex-wrap items-center gap-3 text-xs" style="color:var(--accent)">
              <span>{p.homepage ? 'live ↗ · code ↗' : 'code ↗'}</span>
              {p.detailUrl && (
                <a href={p.detailUrl} class="relative z-10 underline"
                   style="color:var(--accent)">{p.detailLabel ?? 'details →'}</a>
              )}
            </div>
          </div>
        ))}
      </div>
      <a href={`https://github.com/${github?.user ?? 'OnlyOneByte'}`} rel="noopener" target="_blank"
         class="mt-4 inline-block text-sm" style="color:var(--accent)">
        more on GitHub →
      </a>
    </section>

    <!-- Experience (professional history) -->
    <section id="experience" class="mt-16 scroll-mt-20">
      <p class="text-sm" style="color:var(--accent)">$ cat ~/.experience</p>
      <h2 class="mt-2 text-2xl font-extrabold" style="color:var(--text-strong)">Experience</h2>
      <ol class="mt-8 space-y-10 border-l pl-6" style="border-color:var(--border)">
        {experience.map((e) => (
          <li class="relative">
            <span class="absolute -left-[1.7rem] top-1.5 h-3 w-3 rounded-full"
                  style="background:var(--accent)"></span>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4">
              <h3 class="text-lg font-bold" style="color:var(--text-strong)">{e.company}</h3>
              <span class="text-xs" style="color:var(--muted)">{period(e)}</span>
            </div>
            <p class="text-sm" style="color:var(--accent)">{e.role}</p>
            {e.summary && <p class="mt-2 text-sm" style="color:var(--muted)">{e.summary}</p>}
            {e.highlights.length > 0 && (
              <ul class="mt-3 space-y-1 text-sm" style="color:var(--text)">
                {e.highlights.map((h) => (
                  <li class="flex gap-2">
                    <span style="color:var(--accent)">▸</span><span>{h}</span>
                  </li>
                ))}
              </ul>
            )}
            {e.tech.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2 text-xs">
                {e.tech.map((t) => (
                  <span class="rounded-theme border px-2 py-0.5"
                        style="border-color:var(--border);color:var(--accent)">{t}</span>
                ))}
              </div>
            )}
          </li>
        ))}
      </ol>
    </section>

    {github && (
      <section class="mt-16">
        <p class="text-sm" style="color:var(--accent)">$ gh activity</p>
        <div class="mt-4 flex flex-wrap gap-4 text-sm" style="color:var(--muted)">
          <span><span style="color:var(--text-strong)">{github.publicRepos}</span> repos</span>
          <span><span style="color:var(--text-strong)">{github.followers}</span> followers</span>
          {github.recentPushes[0] && (
            <span>last push → <span style="color:var(--text)">{github.recentPushes[0].repo}</span></span>
          )}
        </div>
      </section>
    )}
  </main>
</Base>
