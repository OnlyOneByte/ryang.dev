---
import Base from '@/layouts/Base.astro';
import Game404 from '@/lib/fun/Game404.svelte';
---

<Base title="404 — Angelo Yang" description="Page not found (but here's a game).">
  <main class="mx-auto max-w-2xl px-6 py-16 font-mono">
    <p class="text-sm" style="color:var(--danger)">$ cat {Astro.url.pathname}</p>
    <h1 class="mt-2 text-5xl font-extrabold" style="color:var(--text-strong)">404</h1>
    <p class="mt-2 text-sm" style="color:var(--muted)">
      That page doesn't exist. While you're here — catch some bytes.
    </p>
    <Game404 client:load />
    <a href="/" class="mt-6 inline-block text-sm" style="color:var(--accent)">← back home</a>
  </main>
</Base>
