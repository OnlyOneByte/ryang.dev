---
import Base from '@/layouts/Base.astro';
import { publicClient } from '@/lib/pb/client';

const { slug } = Astro.params;

// Old slug → new, after the angryang.dev → ryang.dev rename. Keeps any existing
// /work/angryang-dev links (shared, indexed) working with a clean 301.
const SLUG_ALIASES: Record<string, string> = { 'angryang-dev': 'ryang-dev' };
if (slug && SLUG_ALIASES[slug]) return Astro.redirect(`/work/${SLUG_ALIASES[slug]}`, 301);

type Project = {
  title: string; summary: string; description?: string;
  tech: string[]; repoUrl?: string; liveUrl?: string; status?: string;
};

let project: Project | null = null;
try {
  const pb = publicClient();
  // bind the user-controlled slug (no raw interpolation → no filter injection)
  const r: any = await pb.collection('projects').getFirstListItem(pb.filter('slug = {:slug}', { slug }));
  project = {
    title: r.title, summary: r.summary, description: r.description,
    tech: r.tech ?? [], repoUrl: r.repoUrl, liveUrl: r.liveUrl, status: r.status,
  };
} catch {
  // dev fallback for the seeded slugs
  const fixtures: Record<string, Project> = {
    'vroom': { title: 'VROOM', summary: 'Self-hosted vehicle cost tracker.', description: '<p>Fuel economy, maintenance schedules, financing/lease math, insurance, and a TCO analytics engine. Offline-first with conflict-resolving sync, money-as-integer-cents, multi-vehicle sharing, and import from Fuelly/Fuelio/Drivvo. 1700+ backend tests.</p>', tech: ['Svelte', 'TypeScript', 'SQLite'], repoUrl: 'https://github.com/OnlyOneByte/VROOM', status: 'active' },
    'ryang-dev': { title: 'ryang.dev', summary: 'This site.', description: '<p>Astro SSR on Bun, Pocketbase backend, a 15-theme CSS-variable engine with a Konami-code unlock, a shared-password recruiter gate, dynamic OG cards, and a 9-container self-hosted companion stack.</p>', tech: ['Astro', 'Bun', 'Pocketbase'], repoUrl: 'https://github.com/OnlyOneByte/ryang.dev', liveUrl: 'https://ryang.dev', status: 'wip' },
    'homelab': { title: 'Homelab', summary: 'Self-hosted services on Docker.', description: '<p>The infrastructure everything runs on: a Docker host with Caddy at the router terminating TLS, privacy-first analytics, self-hosted coding stats, status monitoring, and automated backups. Reproducible via docker compose.</p>', tech: ['Docker', 'Caddy', 'Linux'], status: 'active' },
  };
  project = (slug && fixtures[slug]) || null;
}

if (!project) return Astro.redirect('/work');
---

<Base title={`${project.title} — Work`}>
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <a href="/work" class="text-sm" style="color:var(--accent)">← all work</a>
    <h1 class="mt-3 text-4xl font-extrabold" style="color:var(--text-strong)">{project.title}</h1>
    <p class="mt-2 text-base" style="color:var(--muted)">{project.summary}</p>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
      {project.tech.map((t) => (
        <span class="rounded-theme border px-2 py-0.5"
              style="border-color:var(--border);color:var(--accent)">{t}</span>
      ))}
      {project.repoUrl && (
        <a href={project.repoUrl} class="rounded-theme border px-2 py-0.5"
           style="border-color:var(--border)">repo ↗</a>
      )}
      {project.liveUrl && (
        <a href={project.liveUrl} class="rounded-theme border px-2 py-0.5"
           style="border-color:var(--border)">live ↗</a>
      )}
    </div>

    {project.description && (
      <article class="prose-invert mt-8 max-w-none text-sm leading-relaxed"
               style="color:var(--text)" set:html={project.description} />
    )}
  </main>
</Base>
