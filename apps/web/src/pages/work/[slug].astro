---
import Base from '@/layouts/Base.astro';
import { publicClient } from '@/lib/pb/client';

const { slug } = Astro.params;

type Project = {
  title: string; summary: string; description?: string;
  tech: string[]; repoUrl?: string; liveUrl?: string; status?: string;
};

let project: Project | null = null;
try {
  const pb = publicClient();
  const r: any = await pb.collection('projects').getFirstListItem(`slug = "${slug}"`);
  project = {
    title: r.title, summary: r.summary, description: r.description,
    tech: r.tech ?? [], repoUrl: r.repoUrl, liveUrl: r.liveUrl, status: r.status,
  };
} catch {
  // dev fallback for the seeded slugs
  const fixtures: Record<string, Project> = {
    'homelab-mesh': { title: 'Homelab Mesh', summary: 'Self-hosted orchestration across 3 nodes.', description: '<p>Docker + Caddy + zero-trust across three nodes. Full self-hosted stack with automated TLS and backups.</p>', tech: ['Go', 'Docker'], status: 'active' },
    'vroom': { title: 'VROOM', summary: 'Vehicle cost tracker.', description: '<p>1700+ tests, offline-first sync, analytics engine, money-cents migration.</p>', tech: ['Svelte', 'TS'], status: 'active' },
    'angryang-dev': { title: 'angryang.dev', summary: 'This site.', description: '<p>Astro + Pocketbase, a 15-theme engine with a Konami unlock, recruiter gate, and a self-hosted companion stack.</p>', tech: ['Astro', 'Bun'], status: 'wip' },
  };
  project = (slug && fixtures[slug]) || null;
}

if (!project) return Astro.redirect('/work');
---

<Base title={`${project.title} — Work`}>
  <main class="mx-auto max-w-3xl px-6 py-16 font-mono">
    <a href="/work" class="text-sm" style="color:var(--accent)">← all work</a>
    <h1 class="mt-3 text-4xl font-extrabold" style="color:var(--text-strong)">{project.title}</h1>
    <p class="mt-2 text-base" style="color:var(--muted)">{project.summary}</p>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
      {project.tech.map((t) => (
        <span class="rounded-theme border px-2 py-0.5"
              style="border-color:var(--border);color:var(--accent)">{t}</span>
      ))}
      {project.repoUrl && (
        <a href={project.repoUrl} class="rounded-theme border px-2 py-0.5"
           style="border-color:var(--border)">repo ↗</a>
      )}
      {project.liveUrl && (
        <a href={project.liveUrl} class="rounded-theme border px-2 py-0.5"
           style="border-color:var(--border)">live ↗</a>
      )}
    </div>

    {project.description && (
      <article class="prose-invert mt-8 max-w-none text-sm leading-relaxed"
               style="color:var(--text)" set:html={project.description} />
    )}
  </main>
</Base>
